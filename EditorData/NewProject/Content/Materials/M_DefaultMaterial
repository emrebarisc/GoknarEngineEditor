    <BaseColor>
        <Calculation>
	// Optimized shader graph calculations

mat4 cnodeModelMatrix = finalModelMatrix;

vec3 cnodeObjectScale = vec3(
    length(cnodeModelMatrix[0].xyz),
    length(cnodeModelMatrix[1].xyz),
    length(cnodeModelMatrix[2].xyz)
);

vec3 cnodeLocalPosition = (fragmentPositionWorldSpace * inverse(cnodeModelMatrix)).xyz;
vec3 cnodeWorldSizedPosition = cnodeLocalPosition * cnodeObjectScale;

vec3 cnodeAbsNormal = abs(normalize(vertexNormal));

float cnodeMaxNormalComponent = max(
    cnodeAbsNormal.x,
    max(cnodeAbsNormal.y, cnodeAbsNormal.z)
);

vec2 cnodeGridUV;

if (cnodeAbsNormal.x &gt;= cnodeMaxNormalComponent)
{
    cnodeGridUV = cnodeWorldSizedPosition.zy;
}
else if (cnodeAbsNormal.y &gt;= cnodeMaxNormalComponent)
{
    cnodeGridUV = cnodeWorldSizedPosition.xz;
}
else
{
    cnodeGridUV = cnodeWorldSizedPosition.xy;
}

float cnodeSmallGridScale = 5.0;
float cnodeMajorLineEvery = 5.0;

float cnodeMinorLineThickness = 0.00625;
float cnodeMajorLineThickness = 0.00125;

cnodeGridUV = cnodeGridUV * cnodeSmallGridScale;

vec2 cnodeMinorFraction = fract(cnodeGridUV);
vec2 cnodeMinorDistance = min(cnodeMinorFraction, vec2(1.0) - cnodeMinorFraction);
vec2 cnodeMinorDerivative = max(fwidth(cnodeGridUV), vec2(0.0001));

vec2 cnodeMinorMask2 = vec2(1.0) - smoothstep(
    vec2(cnodeMinorLineThickness),
    vec2(cnodeMinorLineThickness) + cnodeMinorDerivative,
    cnodeMinorDistance
);

float cnodeMinorMask = max(cnodeMinorMask2.x, cnodeMinorMask2.y);

vec2 cnodeMajorUV = cnodeGridUV / cnodeMajorLineEvery;
vec2 cnodeMajorFraction = fract(cnodeMajorUV);
vec2 cnodeMajorDistance = min(cnodeMajorFraction, vec2(1.0) - cnodeMajorFraction);
vec2 cnodeMajorDerivative = max(fwidth(cnodeMajorUV), vec2(0.0001));

vec2 cnodeMajorMask2 = vec2(1.0) - smoothstep(
    vec2(cnodeMajorLineThickness),
    vec2(cnodeMajorLineThickness) + cnodeMajorDerivative,
    cnodeMajorDistance
);

float cnodeMajorMask = max(cnodeMajorMask2.x, cnodeMajorMask2.y);

vec3 cnodeBackgroundColor = vec3(0.62, 0.59, 0.56);
vec3 cnodeMinorLineColor = vec3(0.45, 0.42, 0.40);
vec3 cnodeMajorLineColor = vec3(0.23, 0.21, 0.20);

vec3 cnodeColor = mix(
    cnodeBackgroundColor,
    cnodeMinorLineColor,
    cnodeMinorMask
);

cnodeColor = mix(
    cnodeColor,
    cnodeMajorLineColor,
    cnodeMajorMask
);

vec4 cnodeResult = vec4(cnodeColor, 1.0);
        
#define customResult (cnodeResult)
</Calculation>
        <Result>customResult;</Result>
